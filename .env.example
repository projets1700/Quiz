# Copier en .env à la racine et dans backend/ selon votre setup (voir backend/.env)

# JWT (obligatoire en production)
JWT_SECRET=changez-moi-en-production-32-caracteres-min
JWT_EXPIRES_IN=15m

# URLs (pour CORS et liens email)
APP_URL=http://localhost
API_URL=http://localhost

# Email : true = mode mock (affiche le lien au lieu d'envoyer)
MOCK_EMAIL=true
